    def _get_normalized_timezone(self, time_zone_str: str) -> str:
        """Normalize timezone string from database and return IANA timezone"""
        if not time_zone_str:
            return 'Asia/Kolkata'
        
        normalized = str(time_zone_str).strip().lower()
        
        if normalized in self.timezone_map:
            logger.debug(f"Direct match found for timezone '{time_zone_str}' -> '{self.timezone_map[normalized]}'")
            return self.timezone_map[normalized]

        for key, value in self.timezone_map.items():
            if key and (key in normalized or normalized in key):
                return value
        
        if 'arabic' in normalized and 'arabian' not in normalized:
            return 'Asia/Riyadh'
        if 'arabian' in normalized:
            return 'Asia/Dubai'
        
        logger.warning(f"Unknown timezone '{time_zone_str}' - defaulting to Asia/Kolkata")
        return 'Asia/Kolkata'

    def _cache_all_job_timezones(self):
        """Cache ALL job timezones at once - OPTIMIZED SINGLE QUERY"""
        try:
            logger.info("Caching all job timezones from d_lntassetmaster...")
            with self.prod_engine.connect() as conn:
                results = conn.execute(
                    text("""
                    SELECT DISTINCT jobcode, time_zone
                    FROM "Fuel_Prod".d_lntassetmaster
                    WHERE jobcode IS NOT NULL
                    """)
                ).fetchall()
                
                for row in results:
                    job_code = str(row.jobcode).strip()
                    self.timezone_cache[job_code] = self._get_normalized_timezone(row.time_zone)
                
                logger.info(f"✓ Cached {len(self.timezone_cache)} job timezones")
                
                for job, tz in list(self.timezone_cache.items())[:5]:
                    logger.debug(f"  {job} -> {tz}")
        except Exception as e:
            logger.warning(f"Error caching timezones: {str(e)}")

    def _get_job_timezone_from_assets(self, job_code: str) -> str:
        """Get timezone from cache - O(1) lookup"""
        if job_code in self.timezone_cache:
            return self.timezone_cache[job_code]
        logger.warning(f"Job code {job_code} not found in cache, using default Asia/Kolkata")
        return 'Asia/Kolkata'

    def _convert_rtc_to_job_timezone(self, rtc_time: datetime, job_code: str) -> datetime:
        """
        Interpret rtc_time as job-local time and return it in the job timezone.
        IMPORTANT: Does NOT assume rtc_time is UTC.
        """
        try:
            job_tz_str = self._get_job_timezone_from_assets(job_code)
            job_tz = pytz.timezone(job_tz_str)

            # handle pandas timestamp
            if isinstance(rtc_time, pd.Timestamp):
                rtc_time = rtc_time.to_pydatetime()

            if rtc_time is None:
                return rtc_time

            # Case 1: naive datetime from DB => assume it's already job-local time
            if rtc_time.tzinfo is None:
                return job_tz.localize(rtc_time)

            # Case 2: tz-aware datetime => convert to job timezone
            return rtc_time
 
        except Exception as e:
            logger.warning(f"Timezone conversion error for {job_code}: {str(e)}")
            return rtc_time



