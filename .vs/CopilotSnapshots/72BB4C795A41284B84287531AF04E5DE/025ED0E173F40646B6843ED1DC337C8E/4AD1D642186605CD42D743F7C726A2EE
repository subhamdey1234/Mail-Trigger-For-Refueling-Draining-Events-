    def _get_speed_alerts_query(self):
        """Get the SQL query for fetching speed alerts with 5-sequence validation"""
        
        end_time = datetime.now()
        start_time = end_time - timedelta(minutes=45)
        
        query = text("""
WITH timezone_mapping AS (
    SELECT
        a.*,
        CASE 
            WHEN a.time_zone IS NULL OR a.time_zone = '' 
            THEN 'Asia/Kolkata'
            WHEN a.time_zone = 'Arabic Standard Time'
            THEN 'Asia/Riyadh'
            WHEN a.time_zone = 'Arabian Standard Time'
            THEN 'Asia/Dubai'
            ELSE 'Asia/Kolkata'
        END AS mapped_timezone
    FROM "Fuel_Prod".d_lntassetmaster a
),

params AS (
    SELECT 0.0001::NUMERIC AS move_eps
),

latest_data AS (
    SELECT
        r.rtc AS occurred_on,
        r.tag_29 AS ignition,                                
        r.tag_386::NUMERIC AS latitude,
        r.tag_387::NUMERIC AS longitude,
        tm.jobcode AS job_code,
        tm.asset_code,
        r.deviceid,
        r.tag_388::INT AS speed,
        tm.assettypename,
        tm.movementtype,
        CASE 
            WHEN LOWER(TRIM(COALESCE(vw.ic_name, ''))) IN ('Renewable', 'LTSA IC','renewable','ltsa ic')
            THEN 125
            ELSE 60
        END AS safe_speed_limit,
        tm.mapped_timezone,
        ROW_NUMBER() OVER (PARTITION BY r.deviceid, r.rtc ORDER BY tm.platform_asset_id) AS rn
    FROM timezone_mapping tm
                     
LEFT JOIN "Fuel_Prod"."VW_JOBMASTER" vw
      ON vw.asset_code = tm.asset_code

    JOIN "Fuel_Prod".r_fuel r
      ON tm.platform_asset_id = r.deviceid
    WHERE r.rtc > (CURRENT_TIMESTAMP AT TIME ZONE tm.mapped_timezone - INTERVAL '30 minutes')
      AND r.rtc <= CURRENT_TIMESTAMP AT TIME ZONE tm.mapped_timezone
      AND r.tag_388 IS NOT NULL
),

deduped AS (
    SELECT
        occurred_on, ignition, latitude, longitude, job_code, asset_code,
        deviceid, speed, assettypename, movementtype, safe_speed_limit, mapped_timezone
    FROM latest_data
    WHERE rn = 1
),

with_prev AS (
    SELECT
        d.*,
        LAG(latitude)  OVER (PARTITION BY deviceid ORDER BY occurred_on) AS prev_lat,
        LAG(longitude) OVER (PARTITION BY deviceid ORDER BY occurred_on) AS prev_lon
    FROM deduped d
),

movement_and_limit AS (
    SELECT
        wp.*,
        CASE
            WHEN prev_lat IS NULL OR prev_lon IS NULL THEN TRUE
            WHEN ABS(latitude - prev_lat) >= (SELECT move_eps FROM params)
              OR ABS(longitude - prev_lon) >= (SELECT move_eps FROM params)
            THEN TRUE
            ELSE FALSE
        END AS is_moving,
        CASE WHEN speed > wp.safe_speed_limit THEN TRUE ELSE FALSE END AS over_limit
    FROM with_prev wp
),

runs AS (
    SELECT
        *,
        CASE
            WHEN over_limit = TRUE
             AND COALESCE(LAG(over_limit) OVER (PARTITION BY deviceid ORDER BY occurred_on), FALSE) = FALSE
            THEN 1 ELSE 0
        END AS start_flag
    FROM movement_and_limit
),

grouped AS (
    SELECT
        *,
        SUM(start_flag) OVER (PARTITION BY deviceid ORDER BY occurred_on
                              ROWS UNBOUNDED PRECEDING) AS grp_id
    FROM runs
),

eligible AS (
    SELECT *
    FROM grouped
    WHERE is_moving = TRUE AND over_limit = TRUE
),

streaks AS (
    SELECT
        *,
        COUNT(*) OVER (PARTITION BY deviceid, grp_id) AS streak_len,
        ROW_NUMBER() OVER (PARTITION BY deviceid, grp_id ORDER BY occurred_on) AS rn_in_grp
    FROM eligible
),

first5_min AS (
    SELECT
        deviceid, grp_id,
        MIN(speed) AS min_speed_first5
    FROM streaks
    WHERE rn_in_grp BETWEEN 1 AND 5
    GROUP BY deviceid, grp_id
),

event_starts AS (
    SELECT
        s.deviceid,
        s.job_code,
        s.asset_code,
        s.occurred_on,
        s.ignition,
        s.latitude,
        s.longitude,
        f5.min_speed_first5 AS speed,
        s.assettypename,
        s.movementtype,
        s.safe_speed_limit,
        s.streak_len,
        s.mapped_timezone
    FROM streaks s
    JOIN first5_min f5
      ON s.deviceid = f5.deviceid AND s.grp_id = f5.grp_id
    WHERE s.streak_len >= 5
      AND s.rn_in_grp = 1
)

SELECT
    deviceid, job_code, asset_code, occurred_on, ignition, latitude, longitude,
    speed, assettypename, movementtype, safe_speed_limit, streak_len, mapped_timezone
FROM event_starts
ORDER BY occurred_on asc
        """)
        return query, {"start_time": start_time, "end_time": end_time}
    
    def _get_geofence_alerts_query(self):
        """Get the SQL query for fetching geofence speed violations"""
        return text("""
    WITH job_timezone AS (
        SELECT DISTINCT ON (a.jobcode)
            a.jobcode,
            CASE
                WHEN a.time_zone IS NULL
                  OR a.time_zone = ''
                    THEN 'Asia/Kolkata'
                WHEN a.time_zone = 'Arabic Standard Time'
                    THEN 'Asia/Riyadh'
                WHEN a.time_zone = 'Arabian Standard Time'
                    THEN 'Asia/Dubai'
                ELSE 'Asia/Kolkata'
            END AS mapped_timezone
        FROM "Fuel_Prod".d_lntassetmaster a
        WHERE a.jobcode = ANY(:jobcodes)
    )
    SELECT
        rpt.deviceid::BIGINT AS deviceid,
        rpt.jobcode          AS job_code,
        rpt.asset_code,
        (rpt.start_time AT TIME ZONE jt.mapped_timezone) AS occurred_on,
        rpt.tag_29           AS ignition,
        rpt.tag_386          AS latitude,
        rpt.tag_387          AS longitude,
        rpt.speed,
        rpt.assettypename,
        jt.mapped_timezone
    FROM job_timezone jt
    CROSS JOIN LATERAL "Fuel_Prod".new_speed_limit_report(
        :jobcodes,
        :asset_codes,
        (:start_time AT TIME ZONE jt.mapped_timezone)::timestamp,
        (:end_time   AT TIME ZONE jt.mapped_timezone)::timestamp,
        :speed_limit,
        'Inside Geofence'
    ) AS rpt
    WHERE rpt.jobcode = jt.jobcode
    ORDER BY occurred_on ASC;
    """).bindparams(
        bindparam("jobcodes",    value=[], type_=ARRAY(String())),  # ✅ tells SQLAlchemy it's a text[]
        bindparam("asset_codes", value=[], type_=ARRAY(String())),  # ✅ same for asset_codes
    )

    def _get_geofence_names(self, jobcode: str) -> dict:
        """Fetch all geofence names for a jobcode from d_geo_fence table"""
        cache_key = f"geofence_{jobcode}"
        
        if cache_key in self.geofence_cache:
            return self.geofence_cache[cache_key]
        
        try:
            geofence_map = {}
            with self.prod_engine.connect() as conn:
                results = conn.execute(
                    text("""
                    SELECT id, gf_name
                    FROM "Fuel_Prod".d_geo_fence
                    WHERE job_code = :jobcode
                      AND is_active = TRUE
                      AND gf_name IS NOT NULL
                    ORDER BY gf_name
                    """),
                    {"jobcode": jobcode}
                ).fetchall()
                
                for row in results:
                    geofence_map[str(row.id)] = str(row.gf_name).strip()
            
            self.geofence_cache[cache_key] = geofence_map
            logger.debug(f"Cached {len(geofence_map)} geofences for jobcode {jobcode}")
            return geofence_map
            
        except Exception as error:
            logger.warning(f"Error fetching geofence names for jobcode {jobcode}: {str(error)}")
            return {}

