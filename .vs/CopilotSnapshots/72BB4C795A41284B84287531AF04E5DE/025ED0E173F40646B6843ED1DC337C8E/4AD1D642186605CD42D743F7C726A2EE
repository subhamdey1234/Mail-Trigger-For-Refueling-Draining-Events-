            logger.error(f"✗ Error sending email for jobcode {job_code}: {str(error)}")
            return False

    def _trigger_email_alerts(self, inserted_jobcodes: list = None, minutes: int = 30):
        """Trigger emails for ALL jobcodes with recent alerts"""
        try:
            logger.info("\n" + "=" * 70)
            logger.info("TRIGGERING EMAIL ALERTS")
            logger.info("=" * 70)

            try:
                with self.prod_engine.connect() as conn:
                    all_jobcodes_with_alerts = [
                        row.job_code for row in conn.execute(
                            text("""
                                                   
WITH timezone_mapping AS (
    SELECT
        a.jobcode,
        a.asset_code,
        CASE 
            WHEN a.time_zone IS NULL 
               OR a.time_zone = '' 
                THEN 'Asia/Kolkata'
            WHEN a.time_zone = 'Arabic Standard Time'
                THEN 'Asia/Riyadh'
            WHEN a.time_zone = 'Arabian Standard Time'
                THEN 'Asia/Dubai'
            ELSE 'Asia/Kolkata'
        END AS mapped_timezone
    FROM "Fuel_Prod".d_lntassetmaster a
)
SELECT DISTINCT
    n.job_code
FROM "Fuel_Prod".d_notification n
LEFT JOIN timezone_mapping tm
  ON tm.jobcode = n.job_code
 AND tm.asset_code = n.asset_code
WHERE n.occured_on >=
        (CURRENT_TIMESTAMP AT TIME ZONE tm.mapped_timezone
         - INTERVAL '1 minute' * :minutes)
  AND n.occured_on <=
        (CURRENT_TIMESTAMP AT TIME ZONE tm.mapped_timezone)
  AND n.job_code IS NOT NULL
ORDER BY n.job_code

                            """),
                            {"minutes": minutes}
                        ).fetchall()
                    ]
            except Exception as query_error:
                logger.warning(f"Error fetching jobcodes from d_notification: {str(query_error)}")
                all_jobcodes_with_alerts = inserted_jobcodes if inserted_jobcodes else []

            if not all_jobcodes_with_alerts:
                logger.info("✗ No jobcodes with recent alerts found in d_notification")
                return 0, 0

            logger.info(f"✓ Found {len(all_jobcodes_with_alerts)} unique jobcodes with alerts in last {minutes} minutes")
            
            email_sent_count = 0
            email_failed_count = 0

            for job_code in all_jobcodes_with_alerts:
                try:
                    logger.info(f"\n→ Processing email for jobcode: {job_code}")

                    contact_details = self._get_job_contact_details(job_code)
                    if not contact_details:
                        logger.warning(f"  ✗ Skipping email: No contact details found for {job_code}")
                        email_failed_count += 1
                        continue

                    df_alerts = self._get_inserted_alerts_for_email(job_code, minutes=minutes)
                    if df_alerts.empty:
                        logger.warning(f"  ✗ Skipping email: No alerts found for {job_code} in last {minutes} minutes")
                        email_failed_count += 1
                        continue

                    if 'geofence_name' not in df_alerts.columns:
                        logger.debug("  ⚠ geofence_name column not present in alert data")
                    
                    if self._send_alert_email(job_code, df_alerts, contact_details):
                        email_sent_count += 1
                        logger.info(f"  ✓ Email sent for jobcode {job_code} ({len(df_alerts)} alerts)")
                    else:
                        email_failed_count += 1
                        logger.warning(f"  ✗ Failed to send email for jobcode {job_code}")

                except Exception as jobcode_error:
                    logger.error(f"Error processing email for jobcode {job_code}: {str(jobcode_error)}")
                    email_failed_count += 1
                    continue

            logger.info(f"\n✓ Email trigger completed: {email_sent_count} sent, {email_failed_count} failed")
            return email_sent_count, email_failed_count

        except Exception as error:
            logger.error(f"Error in email trigger process: {str(error)}")
            return 0, 0

    def _insert_alerts_query(self):
        """Optimized insert with duplicate check"""
        return text("""
    INSERT INTO "Fuel_Prod".d_notification (
    job_code, asset_code, deviceid, occured_on, ignition,
    latitude, longitude, speed, assettypename, geofence_name
)
SELECT
    :job_code, :asset_code, :deviceid, :occured_on, :ignition,
    :latitude, :longitude, :speed, :assettypename, :geofence_name       
WHERE NOT EXISTS (
    SELECT 1 FROM "Fuel_Prod".d_notification
    WHERE deviceid = :deviceid
      AND job_code = :job_code
      AND asset_code = :asset_code
      AND occured_on = :occured_on
)
        """)

    def _prepare_alert_row(self, rmap, is_geofence: bool = False, geofence_name: str = 'N/A'):
        """Prepare and convert alert row data with proper geofence_name"""
        row_dict = {
            'job_code': str(rmap.get('job_code') or '').strip(),
            'asset_code': str(rmap.get('asset_code') or '').strip(),
            'deviceid': str(rmap.get('deviceid') or '').strip(),
            'occured_on': rmap.get('occurred_on'),
            'ignition': int(rmap.get('ignition') or 0),
            'latitude': str(rmap.get('latitude') or '0'),
            'longitude': str(rmap.get('longitude') or '0'),
            'speed': str(int(rmap.get('speed') or 0)),
            'assettypename': str(rmap.get('assettypename') or '').strip(),
            'geofence_name': str(geofence_name or 'N/A').strip() if geofence_name else 'N/A'
        }
        return row_dict

    def _insert_single_alert(self, row_dict):
        """Insert a single alert with its own transaction and error handling"""
        try:
            with self.prod_engine.begin() as conn:
                result = conn.execute(self._insert_alerts_query(), row_dict)
                if result.rowcount > 0:
                    logger.debug(f"Inserted alert: Device {row_dict['deviceid']} | "
                               f"Geofence: {row_dict['geofence_name']} | Speed: {row_dict['speed']}")
                return result.rowcount > 0
        except Exception as error:
            logger.warning(f"Failed to insert alert for deviceid {row_dict['deviceid']}: {str(error)}")
            return False

    def process_speed_alerts(self, *, dry_run: bool = False, debug: bool = False):
        """Process and transfer speed alerts from production"""
        inserted_jobcodes = []
        
        try:
            logger.info("\n" + "=" * 70)
            logger.info("PROCESSING SPEED ALERTS")
            logger.info("=" * 70)
            
            logger.info("Fetching speed alerts from PRODUCTION database...")
            with self.prod_engine.connect() as src_conn:
                query, params = self._get_speed_alerts_query()
                results = src_conn.execute(query, params).fetchall()

            if not results:
                logger.info("✗ No new speed alerts to process")
                return 0, 0, inserted_jobcodes

            if results:
                self.last_processed_time = max(row.occurred_on for row in results)
                logger.info(f"✓ Updated last_processed_time to {self.last_processed_time}")

            if debug:
                sample = [dict(r._mapping) for r in results[:5]]
                logger.debug(f"Sample speed alerts (first 5): {sample}")
           
            logger.info(f"✓ Found {len(results)} speed alerts")

            if dry_run:
                logger.info("Dry-run enabled: skipping inserts")
                return len(results), 0, inserted_jobcodes

            inserted_count = 0
            skipped_count = 0
           
            for row in results:
                rmap = row._mapping
                
                if (rmap.get('movementtype') or '').strip().lower() == 'stationary':
                    skipped_count += 1
                    logger.debug(f"Skipped stationary alert for deviceid {rmap.get('deviceid')}")
                    continue
                
                row_dict = self._prepare_alert_row(rmap, is_geofence=False, geofence_name='N/A')
                if self._insert_single_alert(row_dict):
                    inserted_count += 1
                    inserted_jobcodes.append(row_dict['job_code'])
                else:
                    skipped_count += 1
           
            logger.info(f"✓ Speed alerts: {inserted_count} inserted, {skipped_count} skipped")
            return inserted_count, skipped_count, inserted_jobcodes

        except Exception as error:
            logger.error(f"Error in speed alert processing: {str(error)}")
            raise

    def process_geofence_alerts(self, *, dry_run: bool = False, debug: bool = False):
        """Process and transfer geofence speed violations for ALL jobcodes"""
        inserted_jobcodes = []
        
        try:
            logger.info("\n" + "=" * 70)
            logger.info("PROCESSING GEOFENCE ALERTS")
            logger.info("=" * 70)
            
            logger.info("Fetching all unique jobcodes from d_lntassetmaster...")
            with self.prod_engine.connect() as prod_conn:
                all_jobcodes = [
                    row.jobcode for row in prod_conn.execute(
                        text("SELECT DISTINCT jobcode FROM \"Fuel_Prod\".d_lntassetmaster WHERE jobcode IS NOT NULL ORDER BY jobcode")
                    ).fetchall()
                ]

            if not all_jobcodes:
                logger.info("✗ No jobcodes found in d_lntassetmaster")
                return 0, 0, inserted_jobcodes

            logger.info(f"✓ Found {len(all_jobcodes)} unique jobcodes to process")

            with self.prod_engine.connect() as prod_conn:
                geofence_limits = {}
                results = prod_conn.execute(text("""
                    SELECT DISTINCT job_code, speed_limit
                    FROM "Fuel_Prod".d_geo_fence
                    WHERE is_active = TRUE
                      AND lower(shape_type) = 'polygon'
                      AND speed_limit IS NOT NULL
                      AND job_code IN (SELECT DISTINCT jobcode FROM "Fuel_Prod".d_lntassetmaster)
                """)).fetchall()
                
                for row in results:
                    geofence_limits[row.job_code] = row.speed_limit

            if not geofence_limits:
                logger.info("✗ No active polygon geofences found for any jobcodes")
                return 0, 0, inserted_jobcodes

            logger.info(f"✓ Found {len(geofence_limits)} jobcodes with active geofence configurations")

            total_inserted = 0
            total_skipped = 0
            
            end_time = datetime.now()
            start_time = end_time - timedelta(minutes=30)
            
            for jobcode, speed_limit in geofence_limits.items():
                try:
                    logger.info(f"\n→ Processing jobcode: {jobcode} (Speed Limit: {speed_limit} km/h)")
                    
                    geofence_name_map = self._get_geofence_names(jobcode)
                    logger.info(f"  ✓ Found {len(geofence_name_map)} geofences for {jobcode}")
                    
                    if geofence_name_map:
                        for gf_id, gf_name in list(geofence_name_map.items())[:3]:
                            logger.debug(f"    - {gf_name} (ID: {gf_id})")
                    
                    with self.prod_engine.connect() as prod_conn:
                        asset_codes = [
                            row.asset_code for row in prod_conn.execute(
                                text("SELECT DISTINCT asset_code FROM \"Fuel_Prod\".d_lntassetmaster WHERE jobcode = :jobcode"),
                                {"jobcode": jobcode}
                            ).fetchall()
                        ]
                    
                    if not asset_codes:
                        logger.debug(f"  ✗ No assets found for jobcode {jobcode}")
                        continue

                    logger.info(f"  ✓ Found {len(asset_codes)} assets")

                    with self.prod_engine.connect() as prod_conn:
                        results = prod_conn.execute(
                            self._get_geofence_alerts_query(),
                            {
                                "jobcodes": [jobcode],
                                "asset_codes": asset_codes,
                                "start_time": start_time,
                                "end_time": end_time,
                               "speed_limit": speed_limit
                            }
                        ).fetchall()

                    if not results:
                        logger.debug(f"  ✗ No geofence violations for jobcode {jobcode}")
                        continue

                    logger.info(f"  ✓ Found {len(results)} potential violations")

                    if debug:
                        logger.debug(f"  Sample violations (first 3):")
                        for sample in results[:3]:
                            logger.debug(f"    Device: {sample.deviceid} | Speed: {sample.speed}")

                    if dry_run:
                        logger.info(f"  Dry-run: Would insert {len(results)} alerts for {jobcode}")
                        total_inserted += len(results)
                        continue

                    inserted_count = 0
                    skipped_count = 0

                    for row in results:
                        rmap = row._mapping
                        
                        geofence_name_from_report = str(rmap.get('geofence_name') or '').strip()
                        
                        if geofence_name_from_report and geofence_name_from_report != 'N/A':
                            geofence_name = geofence_name_from_report
                        elif geofence_name_map:
                            geofence_name = list(geofence_name_map.values())[0]
                        else:
                            geofence_name = 'N/A'
                        
                        row_dict = self._prepare_alert_row(rmap, is_geofence=True, geofence_name=geofence_name)
                        
                        if self._insert_single_alert(row_dict):
                            inserted_count += 1
                            inserted_jobcodes.append(row_dict['job_code'])
                        else:
                            skipped_count += 1

                    total_inserted += inserted_count
                    total_skipped += skipped_count
                    
                    if inserted_count > 0:
                        logger.info(f"  ✓ Geofence {jobcode}: {inserted_count} inserted, {skipped_count} skipped")
                    
                except Exception as jobcode_error:
                    logger.warning(f"Error processing geofence for jobcode {jobcode}: {str(jobcode_error)}")
                    continue

            logger.info(f"\n✓ Total geofence alerts: {total_inserted} inserted, {total_skipped} skipped")
            return total_inserted, total_skipped, inserted_jobcodes

        except Exception as error:
            logger.error(f"Error in geofence alert processing: {str(error)}")
            raise

